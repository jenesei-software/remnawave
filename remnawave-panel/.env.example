# =========================
# Ubuntu base setup
# =========================
# REQUIRED: change before running setup-ubuntu.sh
ROOT_PASSWORD=change_me_root_password
# REQUIRED: change before running setup-ubuntu.sh
USER_NAME=deploy
# REQUIRED: change before running setup-ubuntu.sh
USER_PASSWORD=change_me_user_password
# REQUIRED: change before running setup-ubuntu.sh
PORT_SSH=10022
# REQUIRED: change before running setup-ubuntu.sh
SSH_PUB="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... your@email"

# Recommended to change for your server
SERVER_IP_V4=203.0.113.10
SERVER_NAME=remnawave-panel-01
SERVER_DOMAIN=panel.example.com

# =========================
# Remnawave Panel setup
# =========================
# REQUIRED: panel public domain
PANEL_DOMAIN=panel.example.com
# REQUIRED: email for acme.sh certificate issuance
DOMAIN_MAIL=admin@example.com

# Optional fallback. When empty and SUBSCRIPTION_PAGE_DOMAIN is set,
# setup-subscription-page.sh uses the subscription domain automatically.
# When both are empty, setup-remnawave-panel.sh falls back to PANEL_DOMAIN/api/sub.
SUB_PUBLIC_DOMAIN=

# =========================
# Bundled subscription page
# =========================
# REQUIRED for bundled subscription-page setup
SUBSCRIPTION_PAGE_DOMAIN=sub.panel.example.com
# REQUIRED for setup-subscription-page.sh
# Create it in Remnawave Dashboard -> Settings -> API Tokens
REMNAWAVE_API_TOKEN=

# Optional / advanced subscription-page settings
CUSTOM_SUB_PREFIX=
MARZBAN_LEGACY_LINK_ENABLED=false
MARZBAN_LEGACY_SECRET_KEY=
CADDY_AUTH_API_TOKEN=

# Optional panel settings
APP_PORT=3000
METRICS_PORT=3001
API_INSTANCES=1
IS_DOCS_ENABLED=false
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
METRICS_USER=admin

# Optional Postgres settings. Password is generated automatically on first run.
POSTGRES_USER=postgres
POSTGRES_DB=postgres
