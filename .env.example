# =========================
# Ubuntu base setup
# =========================
ROOT_PASSWORD=change_me_root_password
USER_NAME=deploy
USER_PASSWORD=change_me_user_password
PORT_SSH=10022
SSH_PUB=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... your@email
SERVER_IP_V4=203.0.113.10
SERVER_NAME=remnawave-prod-01
SERVER_DOMAIN=node.example.com

# =========================
# Remnawave Node setup
# =========================
DOMAIN_MAIL=admin@example.com
PORT_NODE=22222
NODE_SECRET=change_me_super_secret_key

# Comma-separated inbound ports to allow through UFW.
# Example: 30000,30001
PORT_ARRAY_INBOUNDS=30000,30001

# Optional: Docker image tag
REMNAWAVE_NODE_IMAGE=remnawave/node:latest

# Port 8443/tcp for acme.sh is opened automatically by setup-remnawave-node.sh
